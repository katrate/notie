{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Notie",
  "version": "0.1.1",
  "identifier": "com.notie.dev",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Notie",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi",
      "dmg",
      "appimage",
      "deb"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {}
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhBRjFDMzJEMkM2QTdERTgKUldUb2ZXb3NMY1B4aW9QdEdXWlpqY2NQQndrK3l6RzdNNHNqQlF0WWhaelQ3RVFQdXJ5M0UwaGcK",
      "endpoints": [
        "https://github.com/katrate/notie/releases/latest/download/latest.json"
      ]
    }
  }
}
